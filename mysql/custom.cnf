# MySQL 8.0 Production Configuration
# Server: Intel i5 Gen 13 + 64GB RAM
# Target: 600+ concurrent LMS users, exam sessions with 300+ students
# References: MySQL 8.0 Official Docs, Percona Best Practices 2024

[mysqld]
# ============================================
# CONNECTION MANAGEMENT
# ============================================
max_connections = 600
max_user_connections = 550
wait_timeout = 300
interactive_timeout = 300
# Skip reverse DNS lookups for faster connections
skip-name-resolve = ON

# ============================================
# INNODB BUFFER POOL (Most Critical Setting)
# Rule: 70-80% of RAM for dedicated server
# 64GB × 0.375 = 24GB (conservative, leaves room for Apache/PHP workers)
# ============================================
innodb_buffer_pool_size = 24G
innodb_buffer_pool_instances = 16

# ============================================
# INNODB REDO LOG & I/O
# ============================================
innodb_log_file_size = 1G
innodb_log_buffer_size = 64M
# 2 = flush once per second (best perf, slight risk on crash)
innodb_flush_log_at_trx_commit = 2
innodb_flush_method = O_DIRECT
# Prevent double-write overhead for SSDs
innodb_doublewrite = ON

# ============================================
# I/O CAPACITY (adjust based on storage type)
# SSD: 2000-10000, HDD: 200-800, NVMe: 10000+
# ============================================
innodb_io_capacity = 2000
innodb_io_capacity_max = 4000
# Adaptive flushing for consistent write performance
innodb_adaptive_flushing = ON

# ============================================
# THREAD & TABLE HANDLING
# ============================================
thread_cache_size = 256
table_open_cache = 8000
table_definition_cache = 4000
open_files_limit = 65535

# ============================================
# TEMP TABLES
# ============================================
tmp_table_size = 256M
max_heap_table_size = 256M

# ============================================
# PER-CONNECTION BUFFERS
# Keep small: 300 connections × buffer_size = total RAM used
# 300 × 2M = 600MB (acceptable) vs 300 × 4M = 1.2GB (wasteful)
# ============================================
sort_buffer_size = 2M
join_buffer_size = 2M
read_buffer_size = 1M
read_rnd_buffer_size = 1M

# ============================================
# QUERY OPTIMIZATIONS
# ============================================
# Optimize subqueries
optimizer_switch = 'index_merge_intersection=off'
# Reduce lock contention
innodb_lock_wait_timeout = 30
innodb_thread_concurrency = 0

# ============================================
# BINARY LOGGING (enable if you want point-in-time recovery)
# ============================================
# binlog_expire_logs_seconds = 604800
# server-id = 1
# log-bin = mysql-bin

# ============================================
# MONITORING
# Keep OFF unless debugging (saves ~5-10% CPU)
# ============================================
performance_schema = OFF

# ============================================
# CHARACTER SET
# ============================================
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

[client]
default-character-set = utf8mb4
